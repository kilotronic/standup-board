# Copy to `.env` (gitignored) and fill in. Used by docker-compose for self-hosting.
# docker-compose auto-loads `.env` from the repo root.

# Generate a strong random value; rotating it invalidates all client tokens.
SECRET_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional: comma/space-separated GitHub usernames allowed to sign in.
# Empty/unset = anyone with a verified GitHub email may sign in.
# GITHUB_ALLOWED_USERS=
# Optional: only needed if you use the web-page sign-in fallback (device-flow login needs no callback).
# OAUTH_REDIRECT_URL=
